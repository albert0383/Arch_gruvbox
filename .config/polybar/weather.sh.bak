#!/bin/bash

# Imposta la tua cittĂ 
CITY="Firenze"

# Ottieni i dati meteo da wttr.in
METEO=$(curl -s "wttr.in/$CITY?format=%C+%t")
WINDKM=$(curl -s "wttr.in/?format=%w")

# Estrai la descrizione del meteo e la temperatura
CONDITION=$(echo "$METEO" | awk '{print $1}')
TEMP=$(echo "$METEO" | awk '{print $2}')

# Mappatura delle condizioni meteo alle icone
case "$CONDITION" in
"Clear")
  ICON="îŚŤ" # Sole
  ;;
"Sunny")
  ICON="îŚŤ" # Sole
  ;;
"Cloudy")
  ICON="îŤ·" # Nuvoloso
  ;;
"Partly cloudy")
  ICON="îŤ·" # Parzialmente Nuvoloso
  ;;
"Overcast")
  ICON="îŤ·" # Nuvoloso
  ;;
"Rain")
  ICON="îŤ¸" # Pioggia
  ;;
"Drizzle")
  ICON="îŤ¸" # Pioviggine
  ;;
"Thunderstorm")
  ICON="îŤą" # Temporale
  ;;
"Snow")
  ICON="îŤş" # Neve
  ;;
*)
  ICON=" " # Se non riconosciamo la condizione, mettiamo nulla
  ;;
esac

# Mostra icona meteo e temperatura
echo "$CITY $ICON $METEO $WINDKM"
